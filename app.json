{
  "expo": {
    "name": "Chef Mobile",
    "slug": "personalchef",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "chefapp",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "notification": {
      "vapidPublicKey": "BEGLvNDSv2IT7Cgzd6zzJK-xuH1vf2SECu9d6cK1-fMtKlPNQCJeHhn7jqS1t9gFV8qeVqOL8-p4jUjWKjHkbyk"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vkleis.personalchef",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be63f4e0-2dcc-42dc-aab1-19020c8552a2"
      }
    },
    "owner": "vkleis"
  }
}
